{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "node",
    "allowJs": true,
    "outDir": "./dist",
    "rootDir": "./src",
    
    /* Interop Constraints */
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    
    /* Pengaturan Longgar (Penyelamat Deployment) */
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "noEmitOnError": false, 
    "checkJs": false,

    /* Modules */
    "moduleDetection": "force",
    "verbatimModuleSyntax": false,
    "isolatedModules": true,
    
    /* Output */
    "sourceMap": true,
    "declaration": false
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules", 
    "src/seed.ts", 
    "**/*.test.ts"
  ]
}