{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "node",
    "allowJs": true,
    "outDir": "./dist",
    "rootDir": "./src",
    
    /* Interop Constraints */
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    
    /* Type Checking - Dimatikan sementara agar build Vercel lolos */
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    
    /* Modules */
    "moduleDetection": "force",
    "verbatimModuleSyntax": false,
    "isolatedModules": true,
    
    /* Source Maps */
    "sourceMap": true,
    "declaration": false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "**/*.test.ts", "src/seed.ts"]
}